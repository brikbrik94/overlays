diff --git a/scripts/generate_sdf_icon.py b/scripts/generate_sdf_icon.py
new file mode 100644
index 0000000..79c0011
--- /dev/null
+++ b/scripts/generate_sdf_icon.py
@@ -0,0 +1,79 @@
+#!/usr/bin/env python3
+# OE5ITH: SDF icon generator for sprite label backgrounds.
+"""Generate a simple rounded-rectangle SDF icon PNG for MapLibre symbol backgrounds.
+
+No external dependencies required.
+"""
+
+from __future__ import annotations
+
+import argparse
+import math
+import struct
+import zlib
+from pathlib import Path
+from typing import Iterable
+
+
+def sd_rounded_box(px: float, py: float, hx: float, hy: float, radius: float) -> float:
+    qx = abs(px) - (hx - radius)
+    qy = abs(py) - (hy - radius)
+    ox = max(qx, 0.0)
+    oy = max(qy, 0.0)
+    outside = math.hypot(ox, oy)
+    inside = min(max(qx, qy), 0.0)
+    return outside + inside - radius
+
+
+def png_chunk(tag: bytes, data: bytes) -> bytes:
+    return struct.pack(">I", len(data)) + tag + data + struct.pack(">I", zlib.crc32(tag + data) & 0xFFFFFFFF)
+
+
+def write_png_rgba(path: Path, width: int, height: int, pixels: Iterable[bytes]) -> None:
+    raw = b"".join(b"\x00" + row for row in pixels)
+    ihdr = struct.pack(">IIBBBBB", width, height, 8, 6, 0, 0, 0)
+    idat = zlib.compress(raw, level=9)
+    png = b"\x89PNG\r\n\x1a\n" + png_chunk(b"IHDR", ihdr) + png_chunk(b"IDAT", idat) + png_chunk(b"IEND", b"")
+    path.write_bytes(png)
+
+
+def generate_sdf_rows(width: int, height: int, radius: float, spread: float) -> list[bytes]:
+    rows: list[bytes] = []
+    cx = (width - 1) / 2.0
+    cy = (height - 1) / 2.0
+    hx = width / 2.0 - 1.0
+    hy = height / 2.0 - 1.0
+    for y in range(height):
+        row = bytearray()
+        for x in range(width):
+            sd = sd_rounded_box(x - cx, y - cy, hx, hy, radius)
+            normalized = 0.5 - (sd / spread)
+            normalized = max(0.0, min(1.0, normalized))
+            alpha = int(round(normalized * 255.0))
+            row.extend((255, 255, 255, alpha))
+        rows.append(bytes(row))
+    return rows
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description="Generate rounded rectangle SDF icon.")
+    parser.add_argument("--out", default="assets/sprites/sdf/label-bubble-sdf.png", help="Output PNG path")
+    parser.add_argument("--width", type=int, default=128, help="Icon width in px")
+    parser.add_argument("--height", type=int, default=64, help="Icon height in px")
+    parser.add_argument("--radius", type=float, default=16.0, help="Corner radius in px")
+    parser.add_argument("--spread", type=float, default=12.0, help="SDF spread (larger = softer)")
+    args = parser.parse_args()
+    out_path = Path(args.out).expanduser().resolve()
+    out_path.parent.mkdir(parents=True, exist_ok=True)
+    rows = generate_sdf_rows(args.width, args.height, args.radius, args.spread)
+    write_png_rgba(out_path, args.width, args.height, rows)
+    print(f"wrote {out_path}")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())

